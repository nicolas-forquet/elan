msgid "**2. Délimitation de la surface disponible** (facultatif)"
msgstr ""

#: ../../petite_anse.rst:544
msgid "Créer une nouvelle couche (.gpkg ou .shp) de type *polygone*."
msgstr ""

#: ../../petite_anse.rst:552
msgid "L'éditer et délimiter la surface disponible."
msgstr ""

#: ../../petite_anse.rst:557
msgid "Enregistrer et sortir du mode édition."
msgstr ""

